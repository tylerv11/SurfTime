# Supabase — get from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# OpenRouter — get from openrouter.ai/keys (you already have this for OpenClaw)
OPENROUTER_API_KEY=your-openrouter-key-here

# Cron security — any random string, used to verify Vercel Cron calls
CRON_SECRET=generate-a-random-string-here

# Python orchestrator URL (Railway or Supabase Edge Functions in prod)
# Leave blank during local dev — orchestrator writes to conditions.json
PYTHON_ORCHESTRATOR_URL=
